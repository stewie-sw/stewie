; foss_ipex Godot sidecar — render-only, headless on request
; Spec ref: ipex-terrain-sim-spec.md §2 (Godot = renderer + sensor model)

config_version=5

[application]

config/name="foss_ipex_sidecar"
config/description="Render-only sidecar to the Chrono physics authority"
run/main_scene="res://render_test.tscn"
config/features=PackedStringArray("4.6")

[display]

window/size/viewport_width=1024
window/size/viewport_height=768

[rendering]

renderer/rendering_method="forward_plus"
; Anti-aliasing for single still sensor frames (render_fidelity_spec.md §4.1).
; All four are single-frame-safe (no motion vectors / temporal convergence) and
; directly tame the grazing-sun (~5deg) hard-shadow stair-stepping that dominates
; the current look. Forward+ only.
;   msaa_3d=2        -> 4x MSAA (0/1/2/3 = off/2x/4x/8x).
;   screen_space_aa=2-> SMAA (0/1/2 = off/FXAA/SMAA); sharper than FXAA(1) which
;                       blurs stills. TAA is deliberately OFF (needs motion vectors
;                       + multi-frame convergence -> useless for one still).
;   scaling_3d/mode=0-> Bilinear, REQUIRED so scale>1.0 supersamples (do NOT pair
;                       with FSR1/FSR2 -- FSR2 is a temporal upscaler, same caveat).
;   scaling_3d/scale=1.5 -> 2.25x SSAA.
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=2
anti_aliasing/quality/use_taa=false
scaling_3d/mode=0
scaling_3d/scale=1.5
; Grazing-sun shadow fidelity (render_fidelity #1). The ~5deg sun casts long shadows
; whose edges dominate the "plasticy" read when undersampled. A large directional
; atlas + Ultra soft-shadow filter resolves them crisply and lets the sun's physical
; angular size (light_angular_distance, set in sidecar.gd) produce a real PCSS penumbra.
; Paired with a pulled-in directional_shadow_max_distance so the atlas covers the ~5 m
; patch instead of the default 100 m frustum (the texel-density win).
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=5
