# STEWIE frontend — nginx serving the planner UI, proxying the API to the backend
FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY stewie/server/index.html /usr/share/nginx/html/index.html
COPY stewie/server/bodies.json /usr/share/nginx/html/bodies.json
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --retries=4 CMD wget -qO- http://127.0.0.1/healthz >/dev/null || exit 1
